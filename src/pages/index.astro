---
import CotizacionForm from '../components/CotizacionForm.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cotización Sonymat">
	<main>
		<h1>Cotizaciones Sonymat</h1>

		<section class="form-section" aria-label="Datos de la cotización">
			<CotizacionForm />
		</section>

		<section class="preview-section" aria-labelledby="previewTitle">
			<h2 id="previewTitle">Mira tu cotización</h2>
			<embed id="pdfViewer" src="" title="Cotización base" type="application/pdf" />
			<button id="downloadCotizacion" type="button">
				Descarga la cotización
			</button>
		</section>
	</main>
</Layout>

<script>
	import {
		cotizacionFilename,
		cotizacionFromFormData,
		cotizacionTitle,
		createEmptyCotizacion,
		type CotizacionData,
	} from '../lib/cotizacion.js';
	import { createCotizacionPdf } from '../lib/cotizacionPdf.js';

	const formCotizacion = document.getElementById(
		'cotizacionData',
	) as HTMLFormElement | null;
	const pdfViewer = document.getElementById('pdfViewer') as HTMLEmbedElement | null;
	const downloadCotizacion = document.getElementById(
		'downloadCotizacion',
	) as HTMLButtonElement | null;

	let currentPreviewUrl: string | null = null;

	const getCurrentCotizacion = () =>
		formCotizacion
			? cotizacionFromFormData(new FormData(formCotizacion))
			: createEmptyCotizacion();

	const renderPdfPreview = (data: CotizacionData) => {
		if (!pdfViewer) return;

		if (currentPreviewUrl) {
			URL.revokeObjectURL(currentPreviewUrl);
		}

		const doc = createCotizacionPdf(data);
		currentPreviewUrl = String(doc.output('bloburl'));
		pdfViewer.title = cotizacionTitle(data);
		pdfViewer.src = currentPreviewUrl;
	};

	renderPdfPreview(getCurrentCotizacion());

	formCotizacion?.addEventListener('submit', (event) => {
		event.preventDefault();
		renderPdfPreview(getCurrentCotizacion());
	});

	downloadCotizacion?.addEventListener('click', () => {
		const data = getCurrentCotizacion();
		createCotizacionPdf(data).save(cotizacionFilename(data));
	});

	window.addEventListener('beforeunload', () => {
		if (currentPreviewUrl) {
			URL.revokeObjectURL(currentPreviewUrl);
		}
	});
</script>

<style>
	main {
		color: var(--color-text);
		font-size: 20px;
		line-height: 1.6;
		margin: auto;
		max-width: calc(100% - 2rem);
		padding: 2rem 1rem 3rem;
		width: 900px;
	}

	h1,
	h2 {
		color: var(--color-text);
		font-weight: 700;
		line-height: 1;
		text-align: center;
	}

	h1 {
		font-size: 4rem;
		margin-bottom: 1em;
	}

	h2 {
		font-size: 2rem;
		margin-bottom: 1em;
	}

	.preview-section {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-soft);
		margin-top: 3rem;
		padding: 1.25rem;
	}

	embed {
		background: #f8fafc;
		border: 1px solid var(--color-border-strong);
		border-radius: var(--radius-md);
		display: block;
		height: 640px;
		margin: 0 auto;
		width: min(100%, 820px);
	}

	#downloadCotizacion {
		display: block;
		font-size: larger;
		margin: 32px auto;
	}

	.form-section,
	.preview-section {
		min-width: 0;
	}

	@media (min-width: 1080px) {
		main {
			align-items: start;
			display: grid;
			gap: 1.5rem;
			grid-template-columns: minmax(380px, 0.78fr) minmax(620px, 1.22fr);
			max-width: calc(100% - 2rem);
			width: 1560px;
		}

		h1 {
			grid-column: 1 / -1;
			margin-bottom: 0.25em;
		}

		.preview-section {
			margin-top: 0;
			position: sticky;
			top: 1rem;
		}

		.preview-section h2 {
			font-size: 1.6rem;
			margin-bottom: 0.75rem;
		}

		embed {
			height: calc(100vh - 180px);
			min-height: 680px;
			width: 100%;
		}

		#downloadCotizacion {
			margin: 1rem auto 0;
		}
	}

	@media (min-width: 1440px) {
		main {
			grid-template-columns: minmax(440px, 0.7fr) minmax(760px, 1.3fr);
			width: 1720px;
		}

		embed {
			min-height: 760px;
		}
	}

	@media (max-width: 720px) {
		h1 {
			font-size: 3rem;
		}

		embed {
			height: 520px;
		}
	}
</style>
