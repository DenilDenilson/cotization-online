<form action="" id="cotizacionData" class="cotizacion-form">
	<p>Ingrese los datos</p>

	<div class="form-grid">
		<label for="nCotization">
			# de cotización
			<input type="number" id="nCotization" name="nCotization" min="0" />
		</label>
		<label for="dateCotization">
			Fecha de cotización
			<input type="date" id="dateCotization" name="dateCotization" />
		</label>
		<label for="nameCompany">
			Nombre de la empresa
			<input type="text" id="nameCompany" name="nameCompany" />
		</label>
		<label for="rucCompany">
			RUC de la empresa
			<input type="text" id="rucCompany" name="rucCompany" />
		</label>
		<label for="nameClient">
			Contacto del cliente
			<input type="text" id="nameClient" name="nameClient" />
		</label>
		<label for="directionClient">
			Dirección del cliente
			<input type="text" id="directionClient" name="directionClient" />
		</label>
		<label for="asunto" class="full-width">
			Asunto
			<input type="text" id="asunto" name="asunto" />
		</label>
	</div>

	<section class="items-section" aria-labelledby="itemsTitle">
		<div class="items-header">
			<h2 id="itemsTitle">Items</h2>
			<button type="button" id="addCotizacionItem" class="secondary-button">
				Agregar item
			</button>
		</div>

		<div class="items-list" id="cotizacionItems">
			<fieldset class="item-fieldset" data-cotizacion-item>
				<legend>Item #1</legend>
				<button
					type="button"
					class="remove-item-button"
					data-remove-item
					aria-label="Eliminar item 1"
					title="Eliminar item"
				>
					×
				</button>
				<div class="item-grid">
					<label>
						Descripción
						<input type="text" name="itemDescription" />
					</label>
					<label>
						Cantidad
						<input type="number" name="itemAmount" min="0" step="1" />
					</label>
					<label>
						Precio unitario
						<input type="number" name="itemPrice" min="0" step="0.01" />
					</label>
				</div>
			</fieldset>
		</div>
	</section>

	<fieldset class="tax-mode-fieldset">
		<legend>Modo de precios</legend>
		<div class="tax-mode-options">
			<label class="choice-option">
				<input type="radio" name="taxMode" value="exclusive" checked />
				Más IGV
			</label>
			<label class="choice-option">
				<input type="radio" name="taxMode" value="included" />
				IGV incluido
			</label>
		</div>
	</fieldset>

	<div class="form-grid totals-grid">
		<label for="subtotal">
			Subtotal
			<input
				type="number"
				id="subtotal"
				name="subtotal"
				min="0"
				step="0.01"
				value="0.00"
				readonly
			/>
		</label>
		<label for="igv">
			IGV
			<input
				type="number"
				id="igv"
				name="igv"
				min="0"
				step="0.01"
				value="0.00"
				readonly
			/>
		</label>
		<label for="total">
			Total
			<input
				type="number"
				id="total"
				name="total"
				min="0"
				step="0.01"
				value="0.00"
				readonly
			/>
		</label>
	</div>

	<label class="manual-toggle" for="manualTotals">
		<input type="checkbox" id="manualTotals" name="manualTotals" value="true" />
		Editar totales manualmente
	</label>

	<button type="submit">Actualizar cotización</button>
</form>

<template id="cotizacionItemTemplate">
	<fieldset class="item-fieldset" data-cotizacion-item>
		<legend>Item</legend>
		<button
			type="button"
			class="remove-item-button"
			data-remove-item
			aria-label="Eliminar item"
			title="Eliminar item"
		>
			×
		</button>
		<div class="item-grid">
			<label>
				Descripción
				<input type="text" name="itemDescription" />
			</label>
			<label>
				Cantidad
				<input type="number" name="itemAmount" min="0" step="1" />
			</label>
			<label>
				Precio unitario
				<input type="number" name="itemPrice" min="0" step="0.01" />
			</label>
		</div>
	</fieldset>
</template>

<script>
	import {
		calculateCotizacionTotals,
		parseNumberField,
		roundMoneyForConsumer,
		toMoneyInputValue,
		type TaxMode,
	} from '../lib/cotizacion.js';

	const form = document.getElementById('cotizacionData') as HTMLFormElement | null;
	const itemsContainer = document.getElementById('cotizacionItems');
	const addItemButton = document.getElementById('addCotizacionItem');
	const itemTemplate = document.getElementById(
		'cotizacionItemTemplate',
	) as HTMLTemplateElement | null;
	const manualTotalsCheckbox = document.getElementById(
		'manualTotals',
	) as HTMLInputElement | null;
	const subtotalInput = document.getElementById(
		'subtotal',
	) as HTMLInputElement | null;
	const igvInput = document.getElementById('igv') as HTMLInputElement | null;
	const totalInput = document.getElementById('total') as HTMLInputElement | null;

	const getItemRows = () =>
		Array.from(
			itemsContainer?.querySelectorAll<HTMLElement>('[data-cotizacion-item]') ??
				[],
		);

	const updateItemIndexes = () => {
		const items = getItemRows();
		const canRemove = items.length > 1;

		items.forEach((item, index) => {
			const itemNumber = index + 1;
			const legend = item.querySelector('legend');
			const removeButton = item.querySelector<HTMLButtonElement>(
				'[data-remove-item]',
			);

			if (legend) {
				legend.textContent = `Item #${itemNumber}`;
			}

			if (removeButton) {
				removeButton.disabled = !canRemove;
				removeButton.setAttribute('aria-label', `Eliminar item ${itemNumber}`);
			}
		});
	};

	const getCurrentTaxMode = (): TaxMode => {
		const selectedTaxMode = form?.querySelector<HTMLInputElement>(
			'input[name="taxMode"]:checked',
		)?.value;

		return selectedTaxMode === 'included' ? 'included' : 'exclusive';
	};

	const getItemsForTotals = () =>
		getItemRows().map((item) => {
			const amount = parseNumberField(
				item.querySelector<HTMLInputElement>('input[name="itemAmount"]')
					?.value ?? '',
			);
			const price = parseNumberField(
				item.querySelector<HTMLInputElement>('input[name="itemPrice"]')?.value ??
					'',
			);

			return {
				amount,
				price,
				total: roundMoneyForConsumer(amount * price),
			};
		});

	const setTotalsReadOnly = (isReadOnly: boolean) => {
		for (const input of [subtotalInput, igvInput, totalInput]) {
			if (input) {
				input.readOnly = isReadOnly;
			}
		}
	};

	const updateTotals = () => {
		if (manualTotalsCheckbox?.checked) return;

		const totals = calculateCotizacionTotals(
			getItemsForTotals(),
			getCurrentTaxMode(),
		);

		if (subtotalInput) subtotalInput.value = toMoneyInputValue(totals.subtotal);
		if (igvInput) igvInput.value = toMoneyInputValue(totals.igv);
		if (totalInput) totalInput.value = toMoneyInputValue(totals.total);
	};

	const addItem = () => {
		if (!itemsContainer || !itemTemplate) return;

		const newItem = itemTemplate.content.firstElementChild?.cloneNode(
			true,
		) as HTMLElement | null;

		if (!newItem) return;

		itemsContainer.append(newItem);
		updateItemIndexes();
		updateTotals();
		newItem.querySelector<HTMLInputElement>('input')?.focus();
	};

	itemsContainer?.addEventListener('click', (event) => {
		const removeButton = (event.target as HTMLElement).closest(
			'[data-remove-item]',
		);

		if (!removeButton || getItemRows().length <= 1) return;

		removeButton.closest('[data-cotizacion-item]')?.remove();
		updateItemIndexes();
		updateTotals();
	});

	addItemButton?.addEventListener('click', addItem);
	form?.addEventListener('input', (event) => {
		const target = event.target as HTMLInputElement;

		if (['itemAmount', 'itemPrice'].includes(target.name)) {
			updateTotals();
		}
	});
	form?.addEventListener('change', (event) => {
		const target = event.target as HTMLInputElement;

		if (target.name === 'taxMode') {
			updateTotals();
		}
	});
	manualTotalsCheckbox?.addEventListener('change', () => {
		const isManual = manualTotalsCheckbox.checked;
		setTotalsReadOnly(!isManual);

		if (!isManual) {
			updateTotals();
		}
	});
	updateItemIndexes();
	setTotalsReadOnly(true);
	updateTotals();
</script>

<style>
	.cotizacion-form {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-soft);
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding: 1.25rem;
	}

	.cotizacion-form > p {
		color: var(--color-text);
		font-weight: 700;
		margin: 0;
		text-align: center;
	}

	.items-header {
		align-items: center;
		display: flex;
		gap: 1rem;
		justify-content: space-between;
		margin-bottom: 1rem;
	}

	.items-section h2 {
		color: var(--color-text);
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0;
	}

	.form-grid,
	.item-grid {
		display: grid;
		gap: 1rem;
	}

	.form-grid {
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}

	.item-grid {
		align-items: end;
		grid-template-columns: minmax(220px, 1fr) minmax(120px, 0.35fr) minmax(
				140px,
				0.45fr
			);
	}

	.full-width {
		grid-column: 1 / -1;
	}

	label {
		color: var(--color-text-muted);
		display: flex;
		flex-direction: column;
		font-size: 1rem;
		gap: 0.35rem;
	}

	input {
		width: 100%;
	}

	.items-list {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}

	.item-fieldset,
	.tax-mode-fieldset {
		background: var(--color-bg-soft);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		margin: 0;
	}

	.item-fieldset {
		padding: 1.2rem 1rem 1rem;
		position: relative;
	}

	.tax-mode-fieldset {
		padding: 1rem;
	}

	.item-fieldset legend,
	.tax-mode-fieldset legend {
		color: var(--color-warning);
		font-weight: 700;
		padding: 0 0.5rem;
	}

	.tax-mode-options {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.choice-option,
	.manual-toggle {
		align-items: center;
		color: var(--color-text);
		display: inline-flex;
		flex-direction: row;
		gap: 0.5rem;
	}

	.choice-option input,
	.manual-toggle input {
		accent-color: var(--color-accent);
		min-height: auto;
		padding: 0;
		width: auto;
	}

	.totals-grid {
		align-items: end;
	}

	.totals-grid input[readonly] {
		background: #141924;
		color: var(--color-text-muted);
	}

	.manual-toggle {
		font-size: 0.95rem;
	}

	button {
		display: block;
		font-size: 1.25rem;
		margin: 0 auto;
	}

	.secondary-button {
		background: transparent;
		border-color: var(--color-border-strong);
		color: var(--color-text);
		font-size: 0.95rem;
		margin: 0;
	}

	.secondary-button:hover {
		background: var(--color-surface-strong);
	}

	.remove-item-button {
		align-items: center;
		background: #10141d;
		border: 1px solid var(--color-border-strong);
		border-radius: 999px;
		color: var(--color-text-muted);
		display: inline-flex;
		font-size: 1.25rem;
		font-weight: 700;
		height: 2rem;
		justify-content: center;
		line-height: 1;
		margin: 0;
		padding: 0;
		position: absolute;
		right: 0.85rem;
		top: -1.35rem;
		width: 2rem;
	}

	.remove-item-button:not(:disabled):hover {
		background: #2a1d24;
		border-color: #a95268;
		color: #ffc0cb;
	}

	.remove-item-button:disabled {
		color: #6f7a8b;
		cursor: not-allowed;
		opacity: 0.72;
		transform: none;
	}

	@media (max-width: 720px) {
		.items-header {
			align-items: stretch;
			flex-direction: column;
		}

		.item-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
