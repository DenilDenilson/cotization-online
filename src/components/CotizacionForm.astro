---
import { COTIZACION_ITEM_INDEXES } from '../lib/cotizacion.js';
---

<form action="" id="cotizacionData" class="cotizacion-form">
	<p>Ingrese los datos</p>

	<div class="form-grid">
		<label for="nCotization">
			# de cotización
			<input type="number" id="nCotization" name="nCotization" min="0" />
		</label>
		<label for="dateCotization">
			Fecha de cotización
			<input type="date" id="dateCotization" name="dateCotization" />
		</label>
		<label for="nameCompany">
			Nombre de la empresa
			<input type="text" id="nameCompany" name="nameCompany" />
		</label>
		<label for="rucCompany">
			RUC de la empresa
			<input type="text" id="rucCompany" name="rucCompany" />
		</label>
		<label for="nameClient">
			Contacto del cliente
			<input type="text" id="nameClient" name="nameClient" />
		</label>
		<label for="directionClient">
			Dirección del cliente
			<input type="text" id="directionClient" name="directionClient" />
		</label>
		<label for="asunto" class="full-width">
			Asunto
			<input type="text" id="asunto" name="asunto" />
		</label>
	</div>

	<section class="items-section" aria-labelledby="itemsTitle">
		<h2 id="itemsTitle">Items</h2>
		<div class="items-list">
			{
				COTIZACION_ITEM_INDEXES.map((item) => (
					<fieldset class="item-fieldset">
						<legend>Item #{item}</legend>
						<div class="item-grid">
							<label for={`itemDescription${item}`}>
								Descripción
								<input
									type="text"
									id={`itemDescription${item}`}
									name={`itemDescription${item}`}
								/>
							</label>
							<label for={`itemAmount${item}`}>
								Cantidad
								<input
									type="number"
									id={`itemAmount${item}`}
									name={`itemAmount${item}`}
									min="0"
									step="1"
								/>
							</label>
							<label for={`itemPrice${item}`}>
								Precio unitario
								<input
									type="number"
									id={`itemPrice${item}`}
									name={`itemPrice${item}`}
									min="0"
									step="0.01"
								/>
							</label>
						</div>
					</fieldset>
				))
			}
		</div>
	</section>

	<div class="form-grid totals-grid">
		<label for="subtotal">
			Subtotal
			<input type="number" id="subtotal" name="subtotal" min="0" step="0.01" />
		</label>
		<label for="igv">
			IGV
			<input type="number" id="igv" name="igv" min="0" step="0.01" />
		</label>
		<label for="total">
			Total
			<input type="number" id="total" name="total" min="0" step="0.01" />
		</label>
	</div>

	<button type="submit">Actualizar cotización</button>
</form>

<style>
	.cotizacion-form {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-soft);
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding: 1.25rem;
	}

	.cotizacion-form > p,
	.items-section h2 {
		color: var(--color-text);
		font-weight: 700;
		margin: 0;
		text-align: center;
	}

	.items-section h2 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.form-grid,
	.item-grid {
		display: grid;
		gap: 1rem;
	}

	.form-grid {
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}

	.item-grid {
		grid-template-columns: minmax(220px, 1fr) minmax(120px, 0.35fr) minmax(
				140px,
				0.45fr
			);
	}

	.full-width {
		grid-column: 1 / -1;
	}

	label {
		color: var(--color-text-muted);
		display: flex;
		flex-direction: column;
		font-size: 1rem;
		gap: 0.35rem;
	}

	input {
		width: 100%;
	}

	.items-list {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}

	.item-fieldset {
		background: var(--color-bg-soft);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		margin: 0;
		padding: 1rem;
	}

	.item-fieldset legend {
		color: var(--color-warning);
		font-weight: 700;
		padding: 0 0.5rem;
	}

	.totals-grid {
		align-items: end;
	}

	button {
		display: block;
		font-size: 1.25rem;
		margin: 0 auto;
	}

	@media (max-width: 720px) {
		.item-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
